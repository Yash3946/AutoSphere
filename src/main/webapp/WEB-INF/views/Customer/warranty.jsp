<%@ page contentType="text/html;charset=UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<title>AutoSphere | 1 Year Warranty</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #f4f6fb;
}

/* HEADER */
.header {
    padding: 15px 40px;
    background: white;
    border-bottom: 1px solid #ddd;
    font-size: 24px;
    font-weight: bold;
    color: #6a1b9a;
}

/* HERO */
.hero {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, #ede7f6, #f5f5f5);
}

.hero h1 {
    color: #4a148c;
    font-size: 36px;
}

.hero p {
    font-size: 18px;
    color: #555;
}

/* CARDS */
.section {
    padding: 50px;
    text-align: center;
}

.cards {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 30px;
}

.card {
    width: 260px;
    background: white;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

.card h3 {
    color: #6a1b9a;
}

.card p {
    color: #555;
    font-size: 14px;
}

/* BUTTON */
.btn {
    margin-top: 30px;
    padding: 12px 25px;
    background: #e91e63;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
}

/* FOOTER */
.footer {
    background: #3b005a;
    color: white;
    text-align: center;
    padding: 20px;
    margin-top: 40px;
}
</style>

</head>

<body>

<div class="header">
    AutoSphere - 1 Year Warranty
</div>

<div class="hero">
    <h1>1 Year Warranty on Every Car 🚗</h1>
    <p>Drive worry-free with our trusted warranty coverage</p>
</div>

<div class="section">

    <h2>What’s Covered?</h2>

    <div class="cards">

        <div class="card">
            <h3>Engine Protection</h3>
            <p>Complete engine repair & replacement support</p>
        </div>

        <div class="card">
            <h3>Transmission</h3>
            <p>Gearbox & transmission system covered</p>
        </div>

        <div class="card">
            <h3>Electrical Parts</h3>
            <p>Battery, wiring & electronics support</p>
        </div>

        <div class="card">
            <h3>Roadside Assistance</h3>
            <p>24x7 breakdown support anywhere</p>
        </div>

    </div>

    <button class="btn">Claim Warranty</button>

</div>

<div class="footer">
    © 2026 AutoSphere | 1 Year Warranty Program
</div>

</body>
</html>